# Local development defaults. Never expose server/provider secrets through VITE_ variables.
PORT=8787
HOST=127.0.0.1
DATA_DIR=.data
MOCK_AI=true
AI_PROVIDER=mock
VITE_AI_MOCK=true
AI_MODEL=
AI_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
BASIC_AI_PROVIDER=
BASIC_AI_MODEL=
BASIC_AI_API_URL=
BASIC_AI_API_KEY=
BASIC_AI_DAILY_DEBATES=3
BASIC_AI_MAX_ROUNDS=3
BASIC_AI_MAX_INPUT_CHARS=8000
BASIC_AI_MAX_OUTPUT_TOKENS=180
FEEDBACK_TO_EMAIL=
FEEDBACK_FROM_EMAIL=
FEEDBACK_EMAIL_PROVIDER=
FEEDBACK_EMAIL_API_URL=
FEEDBACK_EMAIL_API_KEY=
VITE_DATA_BACKEND=local
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE_URL=
VITE_ANDROID_API_TARGET=device
VITE_APP_BASE_URL=http://127.0.0.1:5173
VITE_APP_ENV=local

# Server-only variables. Never prefix these with VITE_.
APP_ENV=local
APP_BASE_URL=http://127.0.0.1:5173
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,https://localhost
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
