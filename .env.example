# Local development defaults. Never expose server/provider secrets through VITE_ variables.
PORT=8787
HOST=127.0.0.1
DATA_DIR=.data
MOCK_AI=true
AI_PROVIDER=mock
AI_MODEL=
AI_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
VITE_DATA_BACKEND=local
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE_URL=
VITE_APP_BASE_URL=http://127.0.0.1:5173
VITE_APP_ENV=local

# Server-only variables. Never prefix these with VITE_.
APP_ENV=local
APP_BASE_URL=http://127.0.0.1:5173
ALLOWED_ORIGINS=http://127.0.0.1:5173
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
