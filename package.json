{
  "name": "sideshift",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "api": "node --env-file-if-exists=.env --env-file-if-exists=.env.server.local server.mjs",
    "dev:all": "concurrently -k \"npm run api\" \"npm run dev -- --host 127.0.0.1\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "node --env-file-if-exists=.env --env-file-if-exists=.env.server.local server.mjs",
    "validate:env": "node --env-file-if-exists=.env --env-file-if-exists=.env.server.local scripts/validate-env.mjs",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test": "vitest run",
    "test:ai-live": "node scripts/test-ai-live.mjs",
    "setup:providers": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-live-providers.ps1",
    "verify:providers": "node --env-file-if-exists=.env --env-file-if-exists=.env.server.local scripts/verify-live-providers.mjs",
    "verify:providers:live": "node --env-file-if-exists=.env --env-file-if-exists=.env.server.local scripts/verify-live-integrations.mjs",
    "test:supabase": "node --env-file=.env scripts/test-supabase-integration.mjs",
    "test:supabase:private-social": "node --env-file=.env scripts/test-private-social-supabase.mjs",
    "test:supabase:collaboration": "node --env-file=.env scripts/test-collaboration-supabase.mjs",
    "test:rls": "node --env-file=.env scripts/test-supabase-integration.mjs",
    "test:playwright": "python critical_flow_test.py",
    "test:playwright:explore": "python scripts/explore_ai_flow.py",
    "test:playwright:ai": "python scripts/ai_mock_flow.py",
    "test:playwright:person": "python scripts/person_flow_test.py",
    "test:playwright:private-social": "python scripts/private_social_flow.py",
    "test:playwright:team": "python scripts/team_group_flow.py",
    "test:playwright:team-ai": "python scripts/team_ai_review_flow.py",
    "test:playwright:supabase": "python scripts/supabase_challenge_flow.py",
    "test:production-smoke": "node --env-file-if-exists=.env scripts/test-production-smoke.mjs",
    "test:pwa": "node scripts/test-pwa.mjs",
    "audit:frontend-secrets": "node scripts/scan-frontend-secrets.mjs",
    "test:encoding": "node scripts/check-encoding.mjs",
    "audit:deps": "npm audit --omit=dev",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open": "npx cap open android",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:build": "npm run build && npx cap sync android && cd android && gradlew.bat assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/share": "^8.0.1",
    "@heyputer/puter.js": "^2.5.4",
    "@supabase/supabase-js": "^2.110.2",
    "@vitejs/plugin-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
